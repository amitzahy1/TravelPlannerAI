rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Personal Trips (ללא שינוי)
    match /users/{userId}/trips/{tripId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Shared Trips (התיקון הקריטי להצטרפות)
    match /shared-trips/{tripId} {
      // יצירה: כל משתמש מחובר
      allow create: if request.auth != null;

      // קריאה: הבעלים, משתתפים, או מיילים מורשים
      allow read: if request.auth != null && (
        resource.data.owner == request.auth.uid ||
        (resource.data.collaborators is list && request.auth.uid in resource.data.collaborators) ||
        (resource.data.allowedEmails is list && request.auth.token.email in resource.data.allowedEmails)
      );

      // עדכון (הצטרפות לטיול):
      // מותר אם: אתה הבעלים, או משתתף קיים, או...
      // *** התיקון: יש לך את ה-shareId הנכון ביד ***
      allow update: if request.auth != null && (
        resource.data.owner == request.auth.uid ||
        (resource.data.collaborators is list && request.auth.uid in resource.data.collaborators) ||
        // בדיקה שה-ID שהמשתמש שולח תואם ל-ID ששמור בטיול (הוכחה שיש לו לינק)
        (request.resource.data.shareId == resource.data.shareId) ||
        // חריגה לטיולים ישנים: אם הטיול המקורי לא הכיל internal shareId, נאפשר הצטרפות אם יש התאמה ל-ID המסמך (אשר הוא ה-shareId)
        (!("shareId" in resource.data) && request.resource.data.shareId == tripId)
      );

      // מחיקה: רק הבעלים
      allow delete: if request.auth != null && resource.data.owner == request.auth.uid;
    }

    // 3. CollectionGroup Query Rule
    // Required for Hybrid Query Strategy (finding orphaned trips by email)
    // NOTE: For collectionGroup queries, the rule condition must exactly mirror
    // the query's where() filter. Only one condition allowed for query approval.
    match /{path=**}/trips/{tripId} {
      allow read: if request.auth != null && (
        resource.data.ownerEmail == request.auth.token.email ||
        resource.data.userId == request.auth.uid
      );
    }

    // 3. References (ללא שינוי)
    match /users/{userId}/shared-trip-refs/{refId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. System Logs (תיקון שגיאת הרשאות)
    match /users/{userId}/system_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. AI cache — public read (saves API cost across users), but writes
    // restricted to authenticated users so anonymous clients can't poison it.
    match /ai_cache/{hash} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 5. Trip Invites — readable only if the caller knows the exact invite ID
    // (the ID is an unguessable UUID shared via the invite link). We explicitly
    // deny `list` to prevent enumeration of all invites.
    match /trip_invites/{inviteId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // חסימת ברירת מחדל
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
