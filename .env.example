# Copy this file to .env.local and fill in your API keys
# DO NOT commit .env.local to Git!
#
# Gemini API: NOT consumed by the frontend. All AI calls go through the
# Cloudflare Worker (workers/), which holds GEMINI_API_KEY as a Cloudflare
# secret. To run the Worker locally, set GEMINI_API_KEY in workers/.dev.vars
# (gitignored).

VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here

# Firebase (already set in GitHub, but needed for local dev)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
